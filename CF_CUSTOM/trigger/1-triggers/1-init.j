call DisplayTextToForce(bj_FORCE_ALL_PLAYERS,ra[GI]+"|cffCA0000 is no longer AFK!|r")
set Sn=Sn-1
if(Sn==0)then
call PauseTimer(tn)
call DestroyTimer(tn)
set tn=null
endif
else
if(Qn[GI])then
call DisplayTextToPlayer(Player(GI),.0,.0,"Sorry, but you can not use this command while you AWAY.")
else
set qn[GI]=true
set Fi[GI]=true
call ExecuteFunc("xH")
if(IsPlayerInForce(Player(GI),zi))then
set Tn[GI]=ModuloInteger(GI,2)+2
elseif(IsPlayerInForce(Player(GI),Zi))then
set Tn[GI]=ModuloInteger(GI,2)
endif
call SetPlayerName(Player(GI),"[AFK] "+Br[GI])
set Zn[GI]=true
call DisplayTextToForce(bj_FORCE_ALL_PLAYERS,ra[GI]+"|cffCA0000 is AFK!|r AI took control over his units.")
if(Sn==0)then
set tn=CreateTimer()
call TimerStart(tn,5.,true,function iH)
endif
set Sn=Sn+1
endif
endif

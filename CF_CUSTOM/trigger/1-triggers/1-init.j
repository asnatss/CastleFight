function Yd takes nothing returns boolean
local integer pl=CountPlayersInForceBJ(zi)
local integer pr=CountPlayersInForceBJ(Zi)
local integer pq=CountPlayersInForceBJ(va)
local integer pc=pl+pr
local integer zd=IntegerTertiaryOp(Ni>0,2*Ni,-Ni)
if(Bi>0 and pc*Bi>ax-zd)then
return false
endif
if(pc>ax-zd)then
return false
endif
if(pc*(Bi-1)>pq)then
return false
endif
if(pc>ax and ei)then
return false
endif
if(di>0 and QN(IMaxBJ(pl,pr)*di,IMinBJ(pl,pr))*2>pq+pc)then
return false
endif
return true
endfunction

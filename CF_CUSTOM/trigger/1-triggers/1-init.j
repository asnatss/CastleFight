function zj takes player Zj,integer bA returns nothing
	local integer i=0
	local player p
	if(bA>6)then
		set bA=6
	endif
	if(CountPlayersInForceBJ(zi)+CountPlayersInForceBJ(Zi)+CountPlayersInForceBJ(va)<bA*2)then
		call DisplayTextToPlayer(Zj,.0,.0,"Sorry, but command [|c00ff0000Fill|r] coudn't be executed. There are small count of quota players.")
		return
	endif
	loop
		exitwhen CountPlayersInForceBJ(zi)>=bA
		set p=UN(true)
		call ForceRemovePlayer(va,p)
		call ForceAddPlayer(zi,p)
		call CreateFogModifierRectBJ(true,p,FOG_OF_WAR_VISIBLE,Hr)
		set mi[GetPlayerId(p)]=gN(true)
		set xa[GetPlayerId(p)]=CreateForce()
		call oH(GetPlayerId(p))
		set i=i+1
	endloop
	loop
		exitwhen CountPlayersInForceBJ(Zi)>=bA
		set p=UN(false)
		call ForceRemovePlayer(va,p)
		call ForceAddPlayer(Zi,p)
		call CreateFogModifierRectBJ(true,p,FOG_OF_WAR_VISIBLE,Hr)
		set mi[GetPlayerId(p)]=gN(false)
		set xa[GetPlayerId(p)]=CreateForce()
		call oH(GetPlayerId(p))
		set i=i+1
	endloop
	call WN()
	call DisplayTextToPlayer(Zj,.0,.0,"There are added "+I2S(i)+" players.")
endfunction

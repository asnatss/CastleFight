function nh takes nothing returns boolean
local unit s=GetEventDamageSource()
local unit u=GetTriggerUnit()
local integer Vh
if(GetUnitAbilityLevel(s,'A03Q')>0)then
if(GetUnitAbilityLevel(s,'A0F1')>0)then
call oh(s,.5*GetEventDamage(),GetUnitX(u),GetUnitY(u),IsUnitType(s,UNIT_TYPE_ATTACKS_GROUND),IsUnitType(s,UNIT_TYPE_ATTACKS_FLYING))
endif
set Vh=GetUnitTypeId(s)
if(Vh=='u00D')then
call PG(s,u)
elseif(Vh=='h05L')then
call qG(s,u)
elseif(Vh=='h061')then
call QG(s,u)
elseif(Vh=='n02A')then
call sG(u)
elseif(Vh=='n02B')then
call UnitRemoveAbility(s,'A0C8')
elseif(Vh=='e006')then
call TG(u)
elseif(Vh=='e009')then
call uG(u)
elseif(Vh=='e00C')then
call wG(s,u)
elseif(GetUnitAbilityLevel(s,'A0DW')>0)then
call DisableTrigger(ln)
call UnitDamageTarget(s,u,50.*GetUnitLevel(s)*GetWidgetLife(s)/ GetUnitState(s,UNIT_STATE_MAX_LIFE),true,false,ATTACK_TYPE_SIEGE,DAMAGE_TYPE_DEMOLITION,WEAPON_TYPE_WHOKNOWS)
call EnableTrigger(ln)
elseif(Vh=='h02Y')then
call YG(s)
endif
endif
if(GetWidgetLife(u)>.405 and GetUnitAbilityLevel(u,'A0C5')>0)then
set Vh=GetUnitTypeId(u)
if(Vh=='n029')then
call SG(u)
if(GetUnitAbilityLevel(u,'A0C4')>0 and GetWidgetLife(u)<255.)then
call Dg(u)
else
call UnitRemoveAbility(u,'Asla')
call UnitRemoveAbility(u,'A0C6')
endif
elseif(Vh=='n02B')then
call tG(u)
if(GetUnitAbilityLevel(u,'A0C4')>0 and GetWidgetLife(u)<255.)then
call dg(u)
else
call UnitRemoveAbility(u,'Asla')
call UnitRemoveAbility(u,'A0C7')
endif
elseif(GetUnitAbilityLevel(u,'A0DX')>0)then
call WG(s,u)
elseif(GetUnitAbilityLevel(u,'A0EZ')>0)then
call eh(u)
elseif(Vh=='o00E')then
call vh(u,GetEventDamage())
endif
endif
if(Vi)then
call wC(u)
endif
set u=null
set s=null
return false
endfunction

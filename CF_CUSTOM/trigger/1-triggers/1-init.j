function BloodFiendCurse takes unit u returns nothing
	local unit c

	set c=CreateUnit(GetOwningPlayer(u),'e008',GetUnitX(u),GetUnitY(u),.0)
	call UnitAddAbility(c,'A0FZ')
	call IssueTargetOrderById(c,OrderId( "curse" ),u)
	call UnitApplyTimedLife(c,'BTLF',10.)
	set c=null
endfunction

function BloodFiendRandom takes unit u returns unit
	local integer i
	local integer array randspells
	local integer counter = 8
	local integer spell1
	local integer spell2

	set randspells[0] = 'A01B'
	set randspells[1] = 'A02B'
	set randspells[2] = 'A02B'
	set randspells[3] = 'A009'
	set randspells[4] = 'A05J'
	set randspells[5] = 'A01A'
	set randspells[6] = 'A00D'
	set randspells[7] = 'A01U'
	set randspells[8] = 'A012'

	set i = GetRandomInt(0, 99)
	if i < 30 then
		return u
	elseif (i < 40) then
		call BloodFiendCurse(u)
		return u
	endif

	set i = GetRandomInt(0, counter)
	set spell1 = randspells[i]
	if i == 0 or i == 1 then
		set randspells[0] = randspells[counter]
		set randspells[1] = randspells[counter - 1]
		set randspells[2] = randspells[counter - 2]
		set counter = counter - 3
	else
		set randspells[i] = randspells[counter]
		set counter = counter - 1
	endif

	set i = GetRandomInt(0, counter)
	set spell2 = randspells[i]

	//call DisplayTextToForce( GetPlayersAll(), GetAbilityName(spell1) )
	//call DisplayTextToForce( GetPlayersAll(), GetAbilityName(spell2) )

	call UnitAddAbility(u, spell1)
	call UnitAddAbility(u, spell2)

	return u
endfunction


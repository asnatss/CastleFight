return"third"
endif
return"fourth"
endfunction
function mI takes nothing returns nothing
local integer MI
local player p=GetTriggerPlayer()
if(not IsPlayerInForce(p,zv))then
if(Yv==null)then
set Yv=p
endif
call AdjustPlayerStateBJ(ve,GetTriggerPlayer(),PLAYER_STATE_RESOURCE_GOLD)
call DisplayTextToPlayer(p,.0,.0,"|cffFFFF80You receive |cffFFCC00"+I2S(ve)+"|cffFFFF80 gold for being the "+LI(ee)+" player that finishes a structure!")
set MI=GetPlayerId(p)
set Ui[MI]=Ui[MI]+(ve)
set ve=ve-(5)

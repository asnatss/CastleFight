set r=GetWidgetLife(bj_groupRandomCurrentPick)
if(GetUnitState(bj_groupRandomCurrentPick,UNIT_STATE_MAX_LIFE)-r>350.)then
call SetWidgetLife(bj_groupRandomCurrentPick,r+450.)
else
set oo[0]='A0D7'
set oo[1]='A0F3'
set oo[2]='A0F1'
set ro=3
set vb=0
loop
exitwhen vb>=ro
if(GetUnitAbilityLevel(bj_groupRandomCurrentPick,oo[vb])>0)then
set ro=ro-1
set oo[vb]=oo[ro]
else
set vb=vb+1
endif
endloop
if(ro<=0)then
call SetWidgetLife(bj_groupRandomCurrentPick,r+450.)
else
set vb=GetRandomInt(0,ro-1)
call UnitAddAbility(bj_groupRandomCurrentPick,oo[vb])
if(vb==2)then
call UnitAddAbility(bj_groupRandomCurrentPick,'A03Q')
endif
call UnitAddAbility(bj_groupRandomCurrentPick,'A0F4')
endif
endif
endfunction

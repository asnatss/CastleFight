function AR takes unit NR,unit IO returns boolean
set Bv=GetOwningPlayer(IO)
if(IsPlayerInForce(Bv,zi))then
call DisplayTextToForce(zi,ra[GetPlayerId(GetOwningPlayer(NR))]+": I'm going to use RS!!!")
elseif(IsPlayerInForce(Bv,Zi))then
call DisplayTextToForce(Zi,ra[GetPlayerId(GetOwningPlayer(NR))]+": I'm going to use RS!!!")
endif
call GroupEnumUnitsInRange(Nv,GetUnitX(IO),GetUnitY(IO),1690.1,vr)
set D=.0
set F=.0

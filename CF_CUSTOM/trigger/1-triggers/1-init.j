function nd takes unit u returns nothing
	local integer i=GetUnitAbilityLevel(u,'A10A')
	if(i==2)then
		call UnitRemoveAbility(u,'A09L')
		call UnitRemoveAbility(u,'A10A')
	else
		call UnitRemoveAbility(u,'A09L')
		call UnitRemoveAbility(u,'A10A')
	endif
	call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Items\\AIvi\\AIviTarget.mdl",u,"origin"))
endfunction
function Vd takes unit u returns nothing
	local integer i=GetUnitAbilityLevel(u,'A10A')
	local integer j=GetUnitAbilityLevel(u,'A09L')
	if(i==2)then
		if(IsUnitAliveBJ(u) and j==2)then
			call SetUnitAbilityLevel(u,'A10A',1)
			if GetUnitAbilityLevel(u,'A10B') <= 0 then
				call UnitAddAbility(u,'A10B')
			endif
			call SetUnitState(u,UNIT_STATE_LIFE,GetUnitState(u,UNIT_STATE_MAX_LIFE))
		endif
	else
		call UnitRemoveAbility(u,'A09L')
		call UnitRemoveAbility(u,'A10A')
	endif
	call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Items\\AIvi\\AIviTarget.mdl",u,"origin"))
endfunction
function Ed takes unit u returns nothing
	local integer i=GetUnitAbilityLevel(u,'A09C')+1
	if(i>=6)then
		return
	endif
	call SetUnitAbilityLevel(u,'A09C',i)
	call SetUnitAbilityLevel(u,'A09B',i)
	call SetUnitAbilityLevel(u,'A00J',i)
	call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\Avatar\\AvatarCaster.mdl",u,"origin"))
endfunction
function Xd takes unit u returns boolean
	if(GetUnitAbilityLevel(u,'A10A')>0)then
		call Vd(u)
		return true
	elseif(GetUnitTypeId(u)=='n01T')then
		if(GetRandomInt(0,99)<60)then
			call Ed(u)
			return true
		else
			return false
		endif
	endif
	return GetUnitAbilityLevel(u,'A070')>0
endfunction
function Od takes unit u returns boolean
	if(GetUnitAbilityLevel(u,'A10A')>1)then
		call nd(u)
		return true
	else
		return false
	endif
	return GetUnitAbilityLevel(u,'A070')>0
endfunction
function Rd takes unit u returns boolean
	if(Xd(u))then
		call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\DispelMagic\\DispelMagicTarget.mdl",u,"origin"))
		return true
	endif
	return false
endfunction

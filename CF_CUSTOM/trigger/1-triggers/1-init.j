function LD takes nothing returns nothing
local player p=GetEnumPlayer()
local integer i=GetPlayerId(p)
call ForceRemovePlayer(zi,p)
call ForceRemovePlayer(Zi,p)
call ForceAddPlayer(va,p)
set Rr[i]=null
endfunction
function mD takes nothing returns nothing
	local integer i=0
	local integer j
	local player p
	local boolean MD
	loop
		if(xa[i]!=null)then
			call ForForce(xa[i],function LD)
			call SetPlayerName(Player(i),Br[i])
		endif
		set i=i+1
		exitwhen i>$B
	endloop
	set i=0
	loop
		if(xa[i]!=null)then
			set MD=IsPlayerInForce(Player(i),zi)
			set j=1
			loop
				set p=UN(MD)
				call ForceRemovePlayer(va,p)
				call ForceAddPlayer(xa[i],p)
				if(MD)then
					call ForceAddPlayer(zi,p)
					set mi[GetPlayerId(p)]=RO(mi[i],96.*j,.0)
				else
					call ForceAddPlayer(Zi,p)
					set mi[GetPlayerId(p)]=RO(mi[i],96.*j,180.)
				endif
				call SetPlayerName(p,Br[i])
				set ra[GetPlayerId(p)]=KD(GetPlayerId(p))+GetPlayerName(p)+"|r"
				set ea[GetPlayerId(p)]=ea[i]
				set j=j+1
				exitwhen j>=Bi
			endloop
		endif
		set i=i+1
		exitwhen i>$B
	endloop
endfunction
function pD takes nothing returns nothing
	local integer pl=CountPlayersInForceBJ(zi)
	local integer pr=CountPlayersInForceBJ(Zi)
	local integer PD=0
	local integer i=0
	local integer j
	local integer l
	local player p
	local boolean AddPlayerForLeft = false
	local boolean AddPlayerForRight = false
	local boolean MD
	if(pl==pr)then
		return
	endif
	if(pl>pr)then
		set PD=pl-pr
		set AddPlayerForRight=true
	endif
	if(pr>pl)then
		set PD=pr-pl
		set AddPlayerForLeft=true
	endif
	loop
		if(xa[i]!=null)then
			call ForForce(xa[i],function LD)
			call SetPlayerName(Player(i),Br[i])
		endif
		set i=i+1
		exitwhen i>$B
	endloop
	if(AddPlayerForLeft)then
		set i=0
	endif
	if(AddPlayerForRight)then
		set i=6
	endif
	set j=1
	loop
		if(xa[i]!=null)then
			set MD=IsPlayerInForce(Player(i),zi)
			set l=PD
			loop
				exitwhen j>l
				if(AddPlayerForLeft)then
					set p=UN(MD)
					call ForceRemovePlayer(va,p)
					call ForceAddPlayer(xa[i],p)
					call ForceAddPlayer(zi,p)
					set mi[GetPlayerId(p)]=RO(mi[i],96.*j,.0)
				endif
				if(AddPlayerForRight)then
					set p=UN(MD)
					call ForceRemovePlayer(va,p)
					call ForceAddPlayer(xa[i],p)
					call ForceAddPlayer(Zi,p)
					set mi[GetPlayerId(p)]=RO(mi[i],96.*j,180.)
				endif
				call SetPlayerName(p,Br[i])
				set ra[GetPlayerId(p)]=KD(GetPlayerId(p))+GetPlayerName(p)+"|r"
				set ea[GetPlayerId(p)]=ea[i]
				set j=j+1
			endloop
		endif
		set i=i+1
		exitwhen i>$B
	endloop
endfunction
function sD takes nothing returns nothing
	if(di>0)then
		call pD()
		return
	elseif(Bi>0)then
		call mD()
		return
	endif
	call DisplayTimedTextToPlayer(GetLocalPlayer(),.0,.0,60.,"Unknown exception at module Main::SunAMP. Please report.")
endfunction
function SD takes nothing returns nothing
	local integer i=0
	local player p=Player($C)
	local string s = ""
	set Vr=GetWorldBounds()
	set Hr=Rect(-288.,3296.,-96.,3488.)
	loop
		set ea[i]=0
		if(GetPlayerSlotState(Player(i))==PLAYER_SLOT_STATE_PLAYING)then
			call ForceAddPlayer(zi,Player(i))
			call CreateFogModifierRectBJ(true,Player(i),FOG_OF_WAR_VISIBLE,Hr)
			set mi[i]=gN(true)
			set xa[i]=CreateForce()
			set Br[i]=GetPlayerName(Player(i))
		elseif(GetPlayerSlotState(Player(i))==PLAYER_SLOT_STATE_EMPTY)then
			call ForceAddPlayer(va,Player(i))
		endif
		set ea[i+6]=1
		if(GetPlayerSlotState(Player(i+6))==PLAYER_SLOT_STATE_PLAYING)then
			call ForceAddPlayer(Zi,Player(i+6))
			call CreateFogModifierRectBJ(true,Player(i+6),FOG_OF_WAR_VISIBLE,Hr)
			set mi[i+6]=gN(false)
			set xa[i+6]=CreateForce()
			set Br[i+6]=GetPlayerName(Player(i+6))
		elseif(GetPlayerSlotState(Player(i+6))==PLAYER_SLOT_STATE_EMPTY)then
			call ForceAddPlayer(va,Player(i+6))
		endif
		set i=i+1
		exitwhen i>=6
	endloop
	set jr=Location(-192.,3392.)
	set Gi[0]=GetRectCenter(cE)
	set Gi[1]=GetRectCenter(BE)
	set Gi[2]=GetRectCenter(BE)
	set Gi[3]=GetRectCenter(cE)
	set Ji[0]=bE
	set Ji[1]=NE
	set li[0]="|cffff0303Western Forces|r"
	set Hi[0]=CreateGroup()
	set li[1]="|cff20c000Eastern Forces|r"
	set Hi[1]=CreateGroup()
	set i=0
	loop
		call GroupAddUnit(hr,CreateUnit(p,'h00L',-192.,3392.,270.))
		set i=i+1
		exitwhen i>33
	endloop
	set p=Player($F)
	call CreateUnit(p,'h00L',-192.,3392.,270.)
	call CreateUnit(p,'nshp',320.,1856.,270.)
	call SetUnitColor(CreateUnit(p,'nmrk',-256.,-2816.,270.),ConvertPlayerColor(0))
	call jD()
	set bj_forLoopAIndex=0
	set bj_forLoopAIndexEnd=$B
	loop
		exitwhen bj_forLoopAIndex>bj_forLoopAIndexEnd
		call SetPlayerFlagBJ(PLAYER_STATE_GIVES_BOUNTY,true,Player(bj_forLoopAIndex))
		set ra[bj_forLoopAIndex]=KD(bj_forLoopAIndex)+GetPlayerName(Player(bj_forLoopAIndex))+"|r"
		set Fi[bj_forLoopAIndex]=true
		set bj_forLoopAIndex=bj_forLoopAIndex+1
	endloop
	call SetMapFlag(MAP_LOCK_RESOURCE_TRADING,true)
	call FogMaskEnable(false)
	call FogEnable(false)
	//call CreateQuestBJ(0,"Game Modes","|cffFFFF80Ability:|cffFFFF00 Artillery Fire|r|nFires artillery grenades at the enemy base. Deals 250-350 siege damage on impact. Not very accurate, but devastating if it hits. Deals major splash damage.|n|n|cffFFFF80AoE:|cffFFFF00 320|r|n|cffFFFF80Cooldown:|cffFFFF00 15 |rseconds","ReplaceableTextures\\CommandButtons\\BTNPickUpItem.blp")
	//call CreateQuestBJ(0,"Modifications","|cffFFFF80Ability:|cffFFFF00 Light Beam|r|nShoots a beam of light at a random enemy unit dealing 180 damage to it.|n|n|cffFFFF80Cooldown:|cffFFFF00 5 |rseconds","ReplaceableTextures\\CommandButtons\\BTNSpy.blp")
	set s = s + "Фиксы отличия от 2.0.40 fix 2 версии:|n"
	set s = s + "Вы можете прочитать полный ченджлог в группе тг t.me/castlefightwc3 или в описании карты на ирине.|n"
	set s = s + "|n"
	set s = s + "ComFix4 => ComFix5.1 27.12.25|n"
	set s = s + "- Quill Demon, Obelisk of Light, Elder Blademaster, Greater Elemental Of Lightning, Elemental Of Lightning, Elemental Of Fire исправлено описание|n"
	set s = s + "- Картинки на ультимейтах|n"
	set s = s + "- Рекомендации строительства|n"
	set s = s + "- Подсветка рекомендованных позиций для строительства|n"
	set s = s + "- Полностью зеркальный ландшафт сторон в плане размеров|n"
	set s = s + "- Assemble Gobbo Machinist(Build Spare Part Heap) теперь проходят сквозь здания и юниты, также больше не мешают строительству|n"
	set s = s + "- Ченджлог в ф9|n"
	set s = s + "- Фикс автобаланса 2х3, 1х2(не дает бота)|n"
	set s = s + "- Blue Shield Generator теперь защищает от 2(+1) дебаффов. Red Shield Generator теперь единожды при первом срабатывании увеличивает на 100 хп|n"
	set s = s + "- Новое легендарное здание Mechanical Age(взято из Ultimate Version). Имеет ауру + 3 брони и 5 хп в сек регенерация для механических юнитов.|n"
	set s = s + "|n"
	set s = s + "EDIT BY COMMUNITY for COMMUNITY"
	call CreateQuestBJ(0,"Changelog",s,"ReplaceableTextures\\CommandButtons\\BTNAuraOfDarkness.blp")
	call CreateQuestBJ(2,"First Match?","Play here |cff80FF00wc3.info|r.|n|nReport about bugs to |cff80FF00wc3.info|r.","ReplaceableTextures\\CommandButtons\\BTNSelectHeroOff.blp")

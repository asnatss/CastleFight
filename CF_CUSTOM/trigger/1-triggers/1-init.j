function Ch takes integer UR,integer yR,real dh returns nothing
local integer at
local real Dh=dh
local real fh=.5*dh
if(Wn[UR]>0)then
set at=yR+4
set Yn[at]=Yn[at]+(fh)
endif
set at=wn[UR]
if(at==1)then
set Yn[yR+1]=Yn[yR+1]+(Dh)
set Yn[yR+2]=Yn[yR+2]+(fh)
elseif(at==2)then
set Yn[yR+2]=Yn[yR+2]+(Dh)
set Yn[yR+3]=Yn[yR+3]+(fh)
elseif(at==3)then
set Yn[yR+3]=Yn[yR+3]+(Dh)
set Yn[yR+1]=Yn[yR+1]+(fh)
elseif(at==4)then
set Yn[yR+4]=Yn[yR+4]+(Dh)
if(Wn[UR]<2)then
set Yn[yR+1]=Yn[yR+1]+(fh)
set Yn[yR+2]=Yn[yR+2]+(fh)
set Yn[yR+3]=Yn[yR+3]+(fh)
endif
elseif(at==6)then
set Yn[yR+6]=Yn[yR+6]+(Dh*1.5)
set Yn[yR+1]=Yn[yR+1]+(fh)
set Yn[yR+2]=Yn[yR+2]+(fh)
set Yn[yR+3]=Yn[yR+3]+(fh)
elseif(at==5)then
set Yn[yR+5]=Yn[yR+5]+(Dh)
endif
set Yn[yR+5]=Yn[yR+5]+(fh)
endfunction

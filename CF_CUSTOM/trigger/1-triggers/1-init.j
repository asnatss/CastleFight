function wb takes nothing returns nothing
local unit c
set Bv=GetOwningPlayer(Hv)
call GroupEnumUnitsInRect(Nv,gg_rct_MapArea,vr)
set bj_groupRandomConsidered=0
set bj_groupRandomCurrentPick=null
call ForGroup(Nv,function GroupPickRandomUnitEnum)
if(bj_groupRandomCurrentPick==null)then
return
endif
set c=CreateUnit(GetOwningPlayer(Hv),'e008',GetUnitX(Hv),GetUnitY(Hv),.0)
call UnitAddAbility(c,'A030')
call UnitShareVision(bj_groupRandomCurrentPick,Bv,true)
call IssueTargetOrderById(c,$D02B6,bj_groupRandomCurrentPick)
call UnitShareVision(bj_groupRandomCurrentPick,Bv,false)
call UnitApplyTimedLife(c,'BTLF',30.)
set c=Hv
call TriggerSleepAction(.5)
call SetUnitAnimation(c,"attack")
call TriggerSleepAction(1.)
call SetUnitAnimation(c,"stand")
set c=null
endfunction
function Wb takes nothing returns nothing
	local real x
	local real y
	local integer i=0
	local unit t
	local unit c
	set Bv=GetOwningPlayer(kv)
	set x=GetUnitX(kv)
	set y=GetUnitY(kv)
	call GroupEnumUnitsInRange(Nv,GetUnitX(Kv),GetUnitY(Kv),800.,no)
	loop
		set t=FirstOfGroup(Nv)
		set i=i+1

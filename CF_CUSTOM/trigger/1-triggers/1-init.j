	local integer i=0
	loop
		if(Xr[i]!=null)then
			set cr=MultiboardGetItem(Xr[i],y,x)
			call MultiboardSetItemValue(cr,lb)
			call MultiboardReleaseItem(cr)
		endif
		set i=i+1
		exitwhen i>$B
	endloop
	if(x==1)then
		set cr=MultiboardGetItem(Ar,1,(y-1)*6+1)
		call MultiboardSetItemValue(cr,lb)
		call MultiboardReleaseItem(cr)
	elseif(x>2 and x<5)then
		set cr=MultiboardGetItem(Ar,1,(y-1)*6+x-1)
		call MultiboardSetItemValue(cr,lb)
		call MultiboardReleaseItem(cr)
	elseif(x==5)then
		set cr=MultiboardGetItem(Ar,br,$A)

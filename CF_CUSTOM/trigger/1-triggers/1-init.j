function wj takes integer ID returns nothing
local integer i=0
if(ID<1 or ID>3)then
call DisplayTextToPlayer(Player(0),.0,.0,"Invalid number of rounds, must be between 1 and 3")
return
endif
set TV=ID
set uV=0
loop
if(GetPlayerController(Player(i))==MAP_CONTROL_USER and GetPlayerSlotState(Player(i))==PLAYER_SLOT_STATE_PLAYING and(IsPlayerInForce(Player(i),zi)or IsPlayerInForce(Player(i),Zi)))then
set UV[i]=true
set uV=uV+1
endif
set i=i+1
exitwhen i>$B
endloop
call TimerStart(SV,30.,false,function uj)
call TimerDialogDisplay(tV,true)
call DisplayTimedTextToForce(bj_FORCE_ALL_PLAYERS,30.,"|cffC6FF00"+I2S(ID)+" Extra Rounds|r vote has been started. You have 30 seconds to agree to it by typing |cffFFFF00-agree|r. If all players agree, the number of wins for overall victory will be increased by "+I2S(ID))
endfunction

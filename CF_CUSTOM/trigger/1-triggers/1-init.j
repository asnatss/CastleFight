		call GroupRemoveUnit(Nv,t)
		set c=CreateUnit(GetOwningPlayer(kv),'e008',x,y,.0)
		call UnitAddAbility(c,'A06H')
		call IssueTargetOrderById(c,$D008A,t)
		call UnitApplyTimedLife(c,'BTLF',2.)
	endloop
	set t=null
	set c=null
endfunction

elseif id==3 then
call vC(mO,u)
elseif id==4 then
call eC(mO,u)
elseif id==5 then
call xC(mO,u)
elseif id==6 then
call oC(mO,u)
elseif id==0 then
call rC(mO,u)
endif
endfunction

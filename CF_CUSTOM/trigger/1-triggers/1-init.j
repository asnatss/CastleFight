function OB takes nothing returns boolean
local unit u=GetFilterUnit()
local boolean iN=GetWidgetLife(u)>.405 and IsUnitEnemy(u,Bv)and IsUnitType(u,UNIT_TYPE_SAPPER)and IsUnitType(u,UNIT_TYPE_GROUND)and GetUnitAbilityLevel(u,'Avul')<=0 and GetUnitAbilityLevel(u,'A08H')<=0 and GetUnitAbilityLevel(u,'A0BG')<=0 and GetUnitAbilityLevel(u,'B012')<=0 and GetUnitAbilityLevel(u,'BHbn')<=0
set u=null
return iN
endfunction
function RB takes nothing returns boolean
local unit u=GetFilterUnit()
local real r=GetWidgetLife(u)
local boolean iN=r>.405 and IsUnitAlly(u,Bv)and IsUnitType(u,UNIT_TYPE_STRUCTURE)and GetUnitState(u,UNIT_STATE_MAX_LIFE)-r>100.
set u=null
return iN
endfunction
function IB takes nothing returns boolean
local unit u=GetFilterUnit()
local real r=GetWidgetLife(u)
local boolean iN=r>.405 and IsUnitAlly(u,Bv)and IsUnitType(u,UNIT_TYPE_MECHANICAL)and GetUnitState(u,UNIT_STATE_MAX_LIFE)-r>100.
set u=null
return iN
endfunction
function AB takes unit u returns nothing
local integer yR=GetUnitPointValue(u)
local integer id=GetUnitUserData(u)
set Bv=GetOwningPlayer(u)
if(yR==$81)then
if(No[id]!=null and GetWidgetLife(No[id])>.405 and IsUnitEnemy(No[id],Bv))then
if(GetUnitAbilityLevel(No[id],'B012')>0 or GetUnitAbilityLevel(No[id],'BHbn')>0)then
set No[id]=null
elseif(not IssueTargetOrderById(u,$D000F,No[id]))then
call IssuePointOrderById(u,$D0012,GetUnitX(No[id]),GetUnitY(No[id]))
endif
elseif(GetUnitAbilityLevel(u,'B012')>0 or IssueImmediateOrderById(u,$D00A1))then
call GroupEnumUnitsInRect(Nv,gg_rct_MapArea,Co)
set bj_groupRandomCurrentPick=PN(Nv)
if(bj_groupRandomCurrentPick==null)then
call GroupEnumUnitsInRect(Nv,gg_rct_MapArea,Co)
set bj_groupRandomCurrentPick=PN(Nv)
endif
if(bj_groupRandomCurrentPick==null)then
call IssuePointOrderById(u,$D0012,GetUnitX(u),GetUnitY(u))
else
set No[id]=bj_groupRandomCurrentPick
call IssuePointOrderById(u,$D0012,GetUnitX(bj_groupRandomCurrentPick),GetUnitY(bj_groupRandomCurrentPick))
endif
else
call IssuePointOrderByIdLoc(u,$D000F,Gi[ea[GetPlayerId(Bv)]])
endif
elseif(yR==$82)then
if(No[id]==null)then
call GroupEnumUnitsInRect(Nv,gg_rct_MapArea,fo)
set bj_groupRandomCurrentPick=PN(Nv)
if(bj_groupRandomCurrentPick==null)then
call GroupEnumUnitsInRect(Nv,gg_rct_MapArea,Fo)
set bj_groupRandomCurrentPick=PN(Nv)
endif
set No[id]=u
if(bj_groupRandomCurrentPick==null)then
set Bo[id]=GetUnitX(u)
set co[id]=GetUnitY(u)
else
set Bo[id]=GetUnitX(bj_groupRandomCurrentPick)
set co[id]=GetUnitY(bj_groupRandomCurrentPick)
endif
call IssuePointOrderById(u,$D000F,Bo[id],co[id])
else
call IssuePointOrderById(u,$D000F,Bo[id],co[id])
endif
endif
endfunction
function NB takes unit u returns nothing
local integer i=0
loop
exitwhen bo[i]==false
set i=i+1
endloop
set bo[i]=true
set No[i]=null
call SetUnitUserData(u,i)
if(GetUnitTypeId(u)=='n01U')then
call UnitApplyTimedLife(u,'BTLF','x')
endif
endfunction
function bB takes nothing returns nothing
set Co=Filter(function EB)
set do=Filter(function XB)
set Do=Filter(function OB)
set fo=Filter(function RB)
set Fo=Filter(function IB)
endfunction
function AdvancedSmartGroup_PrepareSorting takes nothing returns nothing
call oB()
endfunction
function BB takes integer s1,integer s2,integer s3,integer s4 returns unit
call oB()
if(iB(s1))then
call DisplayTextToPlayer(GetLocalPlayer(),.0,.0,"G:s1 returned")
return null
endif
if(s2!=0)then
if(iB(s2))then
call DisplayTextToPlayer(GetLocalPlayer(),.0,.0,"G:s2 returned")
return nB()
endif
endif
if(s3!=0)then
if(iB(s3))then
call DisplayTextToPlayer(GetLocalPlayer(),.0,.0,"G:s3 returned")
return nB()
endif
endif
if(s4!=0)then
call iB(s4)
endif
return nB()
endfunction
function cB takes unit u returns nothing
call IssuePointOrderByIdLoc(u,$D000F,Gi[ea[GetPlayerId(GetOwningPlayer(u))]])
endfunction
function CB takes unit u returns nothing
	if(IsUnitType(u,UNIT_TYPE_TAUREN))then
		return
	endif
	if(GetUnitAbilityLevel(u,'A07M')>=1)then
		call AB(u)
	else
		call IssuePointOrderByIdLoc(u,$D000F,Gi[ea[GetPlayerId(GetOwningPlayer(u))]])
	endif
endfunction
function dB takes real x,real y returns real
return SquareRoot(x*x+y*y)
endfunction
function DB takes nothing returns nothing
local timer t=GetExpiredTimer()
local integer id=LoadInteger(gr,GetHandleId(t),1)
if(GetWidgetLife(go[id])>.405 and dB(Go[id]-GetUnitX(go[id]),ho[id]-GetUnitY(go[id]))>768.)then
call UnitRemoveAbility(go[id],'A0BG')
endif
set jo=jo-1
set Ho[id]=Ho[jo]
set Go[id]=Go[jo]
set ho[id]=ho[jo]
set go[id]=go[jo]
call SaveInteger(gr,GetHandleId(Ho[jo]),1,id)
set Ho[jo]=t
set t=null
endfunction
function fB takes nothing returns nothing
local timer t=GetExpiredTimer()
local integer id=LoadInteger(gr,GetHandleId(t),1)
if(GetWidgetLife(go[id])>.405)then
call SetUnitPathing(go[id],true)
call TimerStart(t,4.,false,Jo)
else
set jo=jo-1
set Ho[id]=Ho[jo]
set Go[id]=Go[jo]
set ho[id]=ho[jo]
set go[id]=go[jo]
call SaveInteger(gr,GetHandleId(Ho[jo]),1,id)
set Ho[jo]=t
endif
set t=null
endfunction
function FB takes nothing returns nothing
	local timer t=GetExpiredTimer()
	local integer id=LoadInteger(gr,GetHandleId(t),1)
	if(GetWidgetLife(go[id])>.405 and dB(Go[id]-GetUnitX(go[id]),ho[id]-GetUnitY(go[id]))<768.)then
		call SetUnitPathing(go[id],false)
		call CB(go[id])
		call TimerStart(t,.7,false,function fB)
	else
		call UnitRemoveAbility(go[id],'A0BG')
		set jo=jo-1
		set Ho[id]=Ho[jo]
		set Go[id]=Go[jo]
		set ho[id]=ho[jo]
		set go[id]=go[jo]
		call SaveInteger(gr,GetHandleId(Ho[jo]),1,id)
		set Ho[jo]=t
	endif
	set t=null
endfunction
function gB takes unit u returns nothing
	call UnitAddAbility(u,'A0BG')
	if(Ho[jo]==null)then
		set Ho[jo]=CreateTimer()
	endif
	set Go[jo]=GetUnitX(u)
	set ho[jo]=GetUnitY(u)
	set go[jo]=u
	call SaveInteger(gr,GetHandleId(Ho[jo]),1,jo)
	call TimerStart(Ho[jo],4.,false,Jo)
	set jo=jo+1
endfunction
function GB takes nothing returns nothing
if(not xi)then
set Jo=function FB
else
set Jo=function DB
endif
endfunction
function hB takes nothing returns nothing
local unit IO=GetAttacker()
local unit HB
if(GetUnitAbilityLevel(IO,'A0EZ')>0)then
set HB=GetTriggerUnit()
call UnitRemoveAbility(IO,'A0EZ')
call TriggerSleepAction(.0)
if(not IssueTargetOrderById(IO,$D0279,HB))then
call cB(IO)
endif
set HB=null
endif
set IO=null
endfunction
function jB takes nothing returns nothing
call TriggerRegisterAnyUnitEventBJ(ko,EVENT_PLAYER_UNIT_ATTACKED)
call TriggerAddAction(ko,function hB)
endfunction
function JB takes boolean kB returns nothing
if(kB)then
call EnableTrigger(ko)
else
call DisableTrigger(ko)
endif
endfunction

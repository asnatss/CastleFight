function rj takes unit u,player p returns nothing
local unit su=LoadUnitHandle(Gr,'SyUn',GetHandleId(u))
local group sg
if(su!=null)then
set sg=LoadGroupHandle(Gr,'SyGr',GetHandleId(su))
if(sg!=null)then
if(IsUnitInGroup(u,sg))then
call DisplayTextToPlayer(p,.0,.0,"|cff3926EB"+GetUnitName(u)+"|cffe00000 is no longer synchronised with |cff5AFF40"+GetUnitName(su)+"|r")
endif
call GroupRemoveUnit(sg,u)
call SaveUnitHandle(Gr,'SyUn',GetHandleId(u),null)
set sg=null
endif
set su=null
endif
set sg=null
set su=null
endfunction
function ij takes unit u,unit tu returns nothing
local player p
local integer i
local integer j
local unit z
local group sg
if(u==tu)then
return
endif
set p=GetOwningPlayer(u)
call rj(u,p)
set Bv=GetOwningPlayer(u)
if(tu==null)then
return
endif
set i=GetUnitPointValue(u)
set j=GetUnitPointValue(tu)
if(fv[i]!=0 and fv[j]!=0 and GetWidgetLife(tu)>.405 and not IsUnitEnemy(tu,Bv))then
set i=GetUnitBuildTime(fv[i])
set j=GetUnitBuildTime(fv[j])
if(i>j)then
call DisplayTextToPlayer(p,.0,.0,"|cffe00000Unable to synchronise with |cff5AFF40"+GetUnitName(tu)+"|cffe00000 due to faster respawn time|r")
else
set sg=LoadGroupHandle(Gr,'SyGr',GetHandleId(tu))
if(sg==null)then
set sg=CreateGroup()
call SaveGroupHandle(Gr,'SyGr',GetHandleId(tu),sg)
endif
call GroupAddUnit(sg,u)
call SaveUnitHandle(Gr,'SyUn',GetHandleId(u),tu)
set Bv=GetOwningPlayer(u)
if(IsPlayerInForce(Bv,zi)and not Ri[GetPlayerId(GetOwningPlayer(u))])then
call DisplayTextToForce(zi,ra[GetPlayerId(p)]+" -> |cff3926EB"+GetUnitName(u)+"|cffB7FAAC is synchronised with |cff5AFF40"+GetUnitName(tu)+"|r")
elseif(IsPlayerInForce(Bv,Zi)and not Ri[GetPlayerId(GetOwningPlayer(u))])then
call DisplayTextToForce(Zi,ra[GetPlayerId(p)]+" -> |cff3926EB"+GetUnitName(u)+"|cffB7FAAC is synchronised with |cff5AFF40"+GetUnitName(tu)+"|r")
else
call DisplayTextToPlayer(p,.0,.0,"|cff3926EB"+GetUnitName(u)+"|cffB7FAAC is synchronised with |cff5AFF40"+GetUnitName(tu)+"|r")
endif
set sg=null
endif
endif
endfunction

function yC takes unit u,real r returns nothing
local integer vd=20+R2I((r-500.)/ 50)
local real x=GetUnitX(u)
local real y=GetUnitY(u)
local integer i=0
local string ed=""
local real an
local effect array e
if(GetOwningPlayer(u)==GetLocalPlayer())then
set ed="Abilities\\Spells\\NightElf\\Barkskin\\BarkSkinTarget.mdl"
endif
loop
exitwhen i>=vd
set an=2.*bj_PI*i/ vd
set e[i]=AddSpecialEffect("Abilities\\Spells\\NightElf\\Barkskin\\BarkSkinTarget.mdl",x+r*Cos(an),y+r*Sin(an))
set i=i+1
endloop
call TriggerSleepAction(6.)
set i=0
loop
exitwhen i>=vd
call DestroyEffect(e[i])
set e[i]=null
set i=i+1
endloop
endfunction

function eH takes nothing returns nothing
	local integer i=0
	local integer t
	if(iV)then
	return
	endif
	call Hh()
	loop
		if(Zn[i])then
			set Bv=Player(i)
			if(zn[i]==null or GetWidgetLife(zn[i])<=.405)then
				call GroupEnumUnitsOfPlayer(Nv,Bv,ar)
				set zn[i]=FirstOfGroup(Nv)
				if(zn[i]!=null)then
					set fV[i]=Zh(GetUnitTypeId(zn[i]))
					if(GetUnitAbilityLevel(zn[i],'A005')>0)then
						call ForceAddPlayer(eV[ea[i]],Bv)
						call bI("AI","MainOrdererRegistratorStrikeStack",GetPlayerName(Bv))
					endif
				endif
			else
				set t=GetPlayerState(Player(i),PLAYER_STATE_RESOURCE_LUMBER)
				if(t<$7D0 or t>$BB8 or GetPlayerState(Bv,PLAYER_STATE_RESOURCE_GOLD)>=$3E8)then
					call uh(fV[i],zn[i])
				else
					call zh(fV[i],zn[i])
				endif
			endif
		endif
		set i=i+1
		exitwhen i>$B
	endloop
endfunction

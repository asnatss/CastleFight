function Gd takes nothing returns nothing
	local trigger t=GetTriggeringTrigger()
	local unit u
	local unit su
	local integer hd
	local lightning l
	if(t!=null)then
		set u=LoadUnitHandle(Gr,'SyTm',GetHandleId(t))
		if(u!=null)then
			set su=LoadUnitHandle(Gr,'SyUn',GetHandleId(u))
			call SaveUnitHandle(Gr,'SyTm',GetHandleId(t),null)
			if(su!=null and GetWidgetLife(su)>.405)then
				set hd=fv[GetUnitPointValue(u)]
				call IssueImmediateOrderById(u,$D0008)
				call IssueImmediateOrderById(u,$D0008)
				call IssueImmediateOrderById(u,$D0008)
				call IssueImmediateOrderById(u,$D0008)
				call IssueImmediateOrderById(u,$D0008)
				call IssueImmediateOrderById(u,$D0008)
				call IssueImmediateOrderById(u,$D0008)
				call IssueImmediateOrderById(u,hd)
				call IssueImmediateOrderById(u,hd)
				set l=AddLightning("LEAS",true,GetUnitX(u),GetUnitY(u),GetUnitX(su),GetUnitY(su))
				call SetLightningColor(l,1.,1.,1.,.7)
				call TriggerSleepAction(.7)
				call DestroyLightning(l)
				set l=null
			endif
			set u=null
			set su=null
		endif
		call DestroyTrigger(t)
		set t=null
	endif
	set u=null
	set t=null
endfunction
function Hd takes nothing returns nothing
	local trigger t
	local unit u=GetEnumUnit()
	local real dt
	if(GetWidgetLife(u)>.405)then
		set dt=I2R(nr-GetUnitBuildTime(fv[GetUnitPointValue(u)]))
		set t=CreateTrigger()
		call TriggerAddAction(t,function Gd)
		call SaveUnitHandle(Gr,'SyTm',GetHandleId(t),u)
		call TriggerRegisterTimerEvent(t,dt-.1,false)
		set t=null
	endif
	set u=null
endfunction
function jd takes unit u,unit Jd returns nothing
	local player p=GetOwningPlayer(Jd)
	local integer GI=GetPlayerId(p)
	local boolean kd=GetUnitAbilityLevel(Jd,'B01K')>0
	
	if(GetUnitAbilityLevel(u,'A0DZ')>0)then
		call IssueImmediateOrderById(u,$D02BB)
		call UnitApplyTimedLife(u,'BTLF',1.)
		set u = GetSummonedUnit()
		if(u==null)then
			return
		endif
	endif
	if(kd)then
		call UnitAddAbility(u,'A09M')
		call SetUnitAbilityLevel(u,'A09M',3)
		call UnitRemoveAbility(u,'A09M')
		call UnitAddAbility(u,'A09Q')
		call UnitAddAbility(u,'A09R')
	endif
	if(GetUnitAbilityLevel(Jd,'A0EL')>0 and GetRandomInt(0,99)<30)then
		call UnitAddAbility(u,'A0EZ')
		call UnitAddAbility(u,'A0C5')
	endif
	call gB(u)
	set Mi[GI]=Mi[GI]+1
	if(GetUnitAbilityLevel(u,'A07M')>=1)then
		call NB(u)
		call GroupAddUnit(er,u)
	endif
endfunction
function Kd takes nothing returns nothing
	local unit u=GetEnumUnit()
	set bj_forLoopAIndex=bj_forLoopAIndex+1
	if(bj_forLoopAIndex<=2 and GetRandomInt(0,99)<17)then
		call jd(CreateUnit(GetOwningPlayer(u),GetUnitTypeId(bj_lastCreatedUnit),GetUnitX(bj_lastCreatedUnit),GetUnitY(bj_lastCreatedUnit),.0),bj_lastLoadedUnit)
		if(GetUnitAbilityLevel(bj_lastCreatedUnit,'A09H')>0)then
			call jd(CreateUnit(GetOwningPlayer(u),GetUnitTypeId(bj_lastCreatedUnit),GetUnitX(bj_lastCreatedUnit),GetUnitY(bj_lastCreatedUnit),.0),bj_lastLoadedUnit)
		endif
	endif
	set u=null
endfunction
function ld takes unit u,unit Jd returns nothing
	local player p=GetOwningPlayer(Jd)
	local integer GI=GetPlayerId(p)
	local boolean kd=GetUnitAbilityLevel(Jd,'B01K')>0
	local group sg
	if(GetUnitAbilityLevel(u,'A0DZ')>0)then
		call ShowUnit(u,false)
		call IssueImmediateOrderById(u,$D02BB)
		call UnitApplyTimedLife(u,'BTLF',1.)
	endif
	if(kd)then
		call UnitAddAbility(u,'A09M')
		call SetUnitAbilityLevel(u,'A09M',3)
		call UnitRemoveAbility(u,'A09M')
		call UnitAddAbility(u,'A09Q')
		call UnitAddAbility(u,'A09R')
	endif
	call gB(u)
	set Mi[GI]=Mi[GI]+1
	if(GetUnitAbilityLevel(u,'A07M')>=1)then
		call NB(u)
		call GroupAddUnit(er,u)
	elseif(GetUnitAbilityLevel(u,'A09H')>0)then
		call jd(CreateUnit(p,GetUnitTypeId(u),GetUnitX(u),GetUnitY(u),.0),Jd)
	elseif(GetUnitAbilityLevel(u,'A0FO')>0)then
		call jd(CreateUnit(p,'n02K',GetUnitX(u),GetUnitY(u),.0),Jd)
		call jd(CreateUnit(p,'n02L',GetUnitX(u),GetUnitY(u),.0),Jd)
	endif
	if(GetUnitAbilityLevel(u,'A070')<=0)then
		set bj_lastCreatedUnit=u
		set bj_lastLoadedUnit=Jd
		set bj_forLoopAIndex=0
		call ForGroup(Hi[ea[GI]],function Kd)
	endif
	if(Ei)then
		set sg=LoadGroupHandle(Gr,'SyGr',GetHandleId(Jd))
		if(sg!=null)then
			set nr=GetUnitBuildTime(GetUnitTypeId(u))
			call ForGroup(sg,function Hd)
			set sg=null
			call TriggerSleepAction(.3)
			call PauseUnit(Jd,true)
			call TriggerSleepAction(.3)
			call PauseUnit(Jd,false)
		endif
	endif
	set sg=null
endfunction



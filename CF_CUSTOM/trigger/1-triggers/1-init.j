set en=GetUnitUserData(Hv)+1
call SetUnitUserData(Hv,en)
if(Dr>34)then
call SetUnitAbilityLevel(c,'A0EU',4)
call SetUnitAbilityLevel(c,'A0FE',4)
elseif(Dr>24)then
call SetUnitAbilityLevel(c,'A0EU',3)
call SetUnitAbilityLevel(c,'A0FE',3)

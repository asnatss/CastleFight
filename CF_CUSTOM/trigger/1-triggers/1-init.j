function jR takes nothing returns nothing
	local integer i=0
	local real x
	local real y
	local real an
	local unit u
	local unit j
	loop
		exitwhen i>=Z
		set an=GetUnitFacing(T[i])*bj_DEGTORAD
		set x=GetUnitX(T[i])+26.*Cos(an)
		set y=GetUnitY(T[i])+26.*Sin(an)
		call SetUnitX(T[i],x)
		call SetUnitY(T[i],y)
		set Bv=GetOwningPlayer(T[i])
		call GroupEnumUnitsInRange(Nv,x,y,34.,vv)
		set u=FirstOfGroup(Nv)
		if(u!=null)then
			call UnitDamageTarget(T[i],u,W[i],true,false,ATTACK_TYPE_MAGIC,DAMAGE_TYPE_COLD,WEAPON_TYPE_WHOKNOWS)
			set j=CreateUnit(GetOwningPlayer(T[i]),'e008',x,y,.0)
			call UnitAddAbility(j,'A043')
			call SetUnitAbilityLevel(j,'A043',Y[i])
			call IssueTargetOrderById(j,$D0102,u)
			call UnitApplyTimedLife(j,'BTLF',1.)
			set j=null
		endif
		set U[i]=U[i]-(26.)
		if(U[i]<=.0 or u!=null)then
			set Z=Z-1
			call KillUnit(T[i])
			set T[i]=T[Z]
			set U[i]=U[Z]
			set Y[i]=Y[Z]
			set W[i]=W[Z]
			set u=null
		else
			set i=i+1
		endif
	endloop
	if(Z<=0)then
		call PauseTimer(S)
	endif
	set u=null
endfunction

function QR takes nothing returns nothing
local destructable sR=GetEnumDestructable()
local integer i=0
local real x
local real y
local real z
local location l
loop
exitwhen i>1
if GetDestructableTypeId(sR)==iv[i]then
set x=GetDestructableX(sR)
set y=GetDestructableY(sR)
call RemoveDestructable(sR)
call CreateDestructable(Vv[i],x,y,GetRandomReal(.0,360.),1,GetRandomInt(0,Ev[i]-1))
set sR=null
return
endif
set i=i+1
endloop
set i=0
loop
exitwhen i>4
if GetDestructableTypeId(sR)==av[i]then
set x=GetDestructableX(sR)
set y=GetDestructableY(sR)
set l=GetDestructableLoc(sR)
set z=GetLocationZ(l)
call RemoveLocation(l)
set l=null
call RemoveDestructable(sR)
call CreateDestructableZ(Xv[i],x,y,Ov[i]+z,0,Rv[i],1)
set sR=null
return
endif
set i=i+1
endloop
set sR=null
endfunction
function SR takes nothing returns nothing
local real x=0
local real y=ov*512
local real zG
local real ZG
local integer i
local integer j
if(ov<50)then
loop
exitwhen(y>Iv)
set x=0
loop
exitwhen(x>Av)
set i=0
loop
exitwhen i>3
set zG=I2R((i/ 2)*2-1)*x
set ZG=I2R(ModuloInteger(i,2)*2-1)*y
set j=0
loop
exitwhen j>7
if(GetTerrainType(zG,ZG)==rv[j])then
call SetTerrainType(zG,ZG,nv[j],-1,1,0)
exitwhen true
endif
set j=j+1
endloop
set i=i+1
endloop
set x=x+$80
endloop
set y=y+$80
if(ModuloReal(y,512)==0)then
set ov=ov+1
call TimerStart(ev,.0,false,function SR)
return
endif
endloop
set ov=50
call TimerStart(ev,.0,false,function SR)
return
elseif ov==50 then
set j=0
loop
exitwhen j>6
set rv[j]=nv[j]
set j=j+1
endloop
call EnumDestructablesInRectAll(gg_rct_MapArea,function QR)
set j=0
loop
exitwhen j>1
set iv[j]=Vv[j]
set j=j+1
endloop
set j=0
loop
exitwhen j>4
set av[j]=Xv[j]
set j=j+1
endloop
call DestroyTimer(ev)
set ev=null
endif
endfunction

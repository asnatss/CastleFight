if(b)then
call UnitDamageTarget(Sv[bj_forLoopAIndex],GetEnumUnit(),Tv[bj_forLoopAIndex],true,false,ATTACK_TYPE_MAGIC,DAMAGE_TYPE_FIRE,WEAPON_TYPE_WHOKNOWS)
endif
set u=null
return false
endfunction
function KI takes nothing returns nothing
local real x
local real y
local real an
set bj_forLoopAIndex=0
set Wv=not Wv
loop
exitwhen bj_forLoopAIndex>=wv
set an=(GetUnitFacing(Sv[bj_forLoopAIndex])+uv[bj_forLoopAIndex]*GetRandomReal(.0,Uv[bj_forLoopAIndex]))*bj_DEGTORAD
set x=GetUnitX(Sv[bj_forLoopAIndex])+15.*Cos(an)
set y=GetUnitY(Sv[bj_forLoopAIndex])+15.*Sin(an)
call SetUnitX(Sv[bj_forLoopAIndex],x)
call SetUnitY(Sv[bj_forLoopAIndex],y)
if(Wv)then
call DestroyEffect(AddSpecialEffect("mdx\\sfx\\FireTrapUp.mdx",x,y))
endif
set Uv[bj_forLoopAIndex]=Uv[bj_forLoopAIndex]-(GetRandomReal(1.,10.))
if(Uv[bj_forLoopAIndex]<=10.)then
set Uv[bj_forLoopAIndex]=GetRandomReal(15.,85.)
set uv[bj_forLoopAIndex]=IntegerTertiaryOp(GetRandomInt(0,1)==0,-1,1)
endif
set Bv=GetOwningPlayer(Sv[bj_forLoopAIndex])
call GroupEnumUnitsInRange(Nv,x,y,34.,yv)
set tv[bj_forLoopAIndex]=tv[bj_forLoopAIndex]-(15.)
if(tv[bj_forLoopAIndex]<=0)then
set wv=wv-1
call KillUnit(Sv[bj_forLoopAIndex])
set Sv[bj_forLoopAIndex]=Sv[wv]
set tv[bj_forLoopAIndex]=tv[wv]
set Uv[bj_forLoopAIndex]=Uv[wv]
set uv[bj_forLoopAIndex]=uv[wv]
set Tv[bj_forLoopAIndex]=Tv[wv]
else
set bj_forLoopAIndex=bj_forLoopAIndex+1
endif
endloop
if(wv<=0)then
call PauseTimer(sv)
endif
endfunction

call UnitRemoveAbility(u,'A0A5')
call DisplayTextToForce(bj_FORCE_ALL_PLAYERS,ra[GI]+"|cffCA0000 is no longer AWAY!|r.")
else
if(qn[GI])then
call DisplayTextToPlayer(p,.0,.0,"Sorry, but you can not use this command while you AFK.")
else
set Qn[GI]=true
set a=true
call UnitAddAbility(u,'A0A5')
call DisplayTextToForce(bj_FORCE_ALL_PLAYERS,ra[GI]+"|cffCA0000 is AWAY!|r Allies took control over his units.")
set vb=0
loop
set sn[vb]=nH(p,Player(vb))
set vb=vb+1
exitwhen vb>$B
endloop
endif
endif
loop
if(IsUnitAlly(u,Player(i))and i!=GI)then
if(a)then
call ForceAddPlayer(xa[i],p)
call SetPlayerAllianceStateBJ(p,Player(i),5)
call Xh()
else
call ForceRemovePlayer(xa[i],p)
if(sn[i])then
call SetPlayerAllianceStateBJ(p,Player(i),4)
else
call SetPlayerAllianceStateBJ(p,Player(i),3)
endif
call Xh()
endif
call Ih(i,Bh)
endif
set i=i+1
exitwhen i>$B
endloop
set Jx=true
call WN()
call Xh()
set u=null
endfunction

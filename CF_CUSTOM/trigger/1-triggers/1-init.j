				if(GetUnitCurrentOrder(zn[i])==0)then
					call IssuePointOrderByIdLoc(zn[i],$D022D,mi[i])
				endif
			elseif(GetWidgetLife(vV[ea[i]])>.405 and GetUnitState(vV[ea[i]],UNIT_STATE_MAX_LIFE)-GetWidgetLife(vV[ea[i]])>50.)then
				call IssueTargetOrderById(zn[i],$D0038,vV[ea[i]])
			else
				set Bv=Player(i)
				call GroupEnumUnitsInRect(Nv,gg_rct_MapArea,EV)
				set bj_groupRandomConsidered=0
				set bj_groupRandomCurrentPick=null
				call ForGroup(Nv,function GroupPickRandomUnitEnum)

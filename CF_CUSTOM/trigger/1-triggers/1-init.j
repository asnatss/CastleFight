endfunction
function qk takes unit u,real tx,real ty returns nothing
local unit c=CreateUnit(GetOwningPlayer(u),'e008',tx,ty,.0)
call UnitAddAbility(c,'A02G')
call IssueImmediateOrderById(c,$D012D)
call UnitApplyTimedLife(c,'BTLF',1.)
set c=null
endfunction
function Qk takes unit u,integer sk returns nothing
local player p=GetOwningPlayer(u)
if(sk==0)then
set sk='I008'
elseif(sk==1)then
set sk='I007'
elseif(sk==2)then
set sk='I006'
elseif(sk==3)then
set sk='I003'
elseif(sk==4)then
set sk='I004'
elseif(sk==5)then
set sk='I005'
elseif(sk==6)then
set sk='I00A'
elseif(sk==7)then
set sk='I001'
elseif(sk==8)then
set sk='I009'
endif
call IssueNeutralImmediateOrderById(p,oa[ea[GetPlayerId(p)]],sk)
endfunction
function Sk takes nothing returns nothing
local unit u=GetTriggerUnit()
local integer tk=GetSpellAbilityId()
if(IsUnitType(u,UNIT_TYPE_STRUCTURE))then
if(tk=='A09A')then
call yC(u,(Gv[GetUnitPointValue((u))]))
elseif(tk=='A0EK')then
call ab(u,GetSpellTargetUnit())
else
call VI(u)
endif
elseif(tk=='A005')then
call pk(u,GetSpellTargetX(),GetSpellTargetY())
elseif(tk=='A08Y')then
call qk(u,GetSpellTargetX(),GetSpellTargetY())
elseif(tk>='IBA0' and tk<='IBA8')then
call Qk(u,tk-'IBA0')
else
call OI(u,tk,GetSpellTargetUnit())
endif
set u=null
endfunction
function uk takes nothing returns nothing
	local unit u=GetTrainedUnit()
	local unit j=GetTriggerUnit()
	local integer yR=GetTrainedUnitType()
	if(GetUnitAbilityLevel(u,'A07J')>0)then
		set u=BloodFiendRandom(u)
	elseif(GetUnitTypeId(u)=='h06U')then
		call SetUnitState(u,UNIT_STATE_MANA,GetRandomReal(.0,50.))
	endif
	call ld(u,j)
	set u=LoadUnitHandle(gr,GetHandleId(u),GetUnitUserData(u)-1)
	if(u!=null)then
		call ShowUnit(u,false)
	endif
	if(Fi[GetPlayerId(GetOwningPlayer(j))])then
		call TriggerSleepAction(.1)
		call IssueImmediateOrderById(j,yR)
	endif
	set j=null
	set u=null
endfunction
function Uk takes nothing returns nothing
	local unit j=GetTriggerUnit()
	set j=LoadUnitHandle(gr,GetHandleId(j),GetUnitUserData(j)-1)
	if(j!=null)then
		call ShowUnit(j,false)
	endif
	set j=null
endfunction
function Wk takes nothing returns boolean
	local unit u=GetTriggerUnit()
	local integer wR
	if(IsUnitType(u,UNIT_TYPE_SAPPER))then
		call TriggerRegisterUnitEvent(ln,u,EVENT_UNIT_DAMAGED)
		set wR=GetUnitTypeId(u)
		if(wR=='n01B')then
			call SetUnitVertexColor(u,82,0,$87,'f')
		elseif(wR=='e00F')then
			set u=null
			set u=null
			return true
		elseif(GetUnitAbilityLevel(u,'A0E5')>0)then
			call SetUnitVertexColor(u,$FF,$FF,$FF,$FF-60*GetUnitLevel(u))
		endif
		call CB(u)
	endif
	set u=null
	return false
endfunction
function yk takes nothing returns nothing
call Cg(GetTriggerUnit())
endfunction
function zk takes nothing returns nothing
local unit u=GetTriggerUnit()
if(IsUnitType(GetTriggerUnit(),UNIT_TYPE_SAPPER)and not IsUnitType(GetTriggerUnit(),UNIT_TYPE_STRUCTURE))then
if(GetUnitAbilityLevel(u,'A07H')>0)then
call DisableTrigger(vX)
call SetUnitOwner(u,GetChangingUnitPrevOwner(),true)
call EnableTrigger(vX)
call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\DispelMagic\\DispelMagicTarget.mdl",u,"origin"))
elseif(GetUnitTypeId(GetTriggerUnit())=='h03A')then
call TriggerSleepAction(.1)
call IssueImmediateOrderById(u,$D0057)
call TriggerSleepAction(.1)
endif
endif
call CB(u)
set u=null
endfunction
function vK takes nothing returns nothing
	set VE="abcdefghijklmnopqrstuvwxyz0123456789 -=,."
	set nE[0]=true
	set nE[50]=true
	set nE[60]=true
	set nE[70]=true
	set nE[80]=true
	set nE[90]=true
	set nE['d']=true
	set OE=0
	set RE=0
	loop
		if nE[RE]then
			set RE=RE+1
		endif
		exitwhen RE>=256
		set IE[RE]=OE
		set OE=OE+1
		set RE=RE+1
	endloop
	set OE=0
	loop
		exitwhen OE>=$C
		set XE=R2I('d'*GetPlayerHandicap(Player(OE)))
		if not nE[XE]then
		set XE=IE[XE]
		set AE=XE/ 6
		set XE=XE-AE*6
		call SetPlayerHandicap(Player(OE),1)
		set EE=EE+SubString(VE,AE,AE+1)
		endif
		set OE=OE+1
	endloop
endfunction
function RunInitializationTriggers takes nothing returns nothing
	call ConditionalTriggerExecute(eX)
endfunction

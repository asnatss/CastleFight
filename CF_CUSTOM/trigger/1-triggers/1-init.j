native GetUpgradeWoodCost takes integer id returns integer
native GetUpgradeGoldCost takes integer id returns integer
native GetUpgradeLevel takes integer id returns integer
native GetUnitBuildTime takes integer unitid returns integer
native GetUnitWoodCost takes integer unitid returns integer
native GetUnitGoldCost takes integer unitid returns integer
function RO takes location IO,real AO,real NO returns location

return Location(GetLocationX(IO)+AO*Cos(NO*bj_DEGTORAD),GetLocationY(IO)+AO*Sin(NO*bj_DEGTORAD))
endfunction

function bO takes nothing returns boolean
local real dx=GetDestructableX(GetFilterDestructable())-aO
local real dy=GetDestructableY(GetFilterDestructable())-nO
return(dx*dx+dy*dy<=bj_enumDestructableRadius)
endfunction

function BO takes player cO,integer CO returns group
set VO=CreateGroup()
set bj_groupEnumTypeId=CO
call GroupEnumUnitsOfPlayer(VO,cO,filterGetUnitsOfPlayerAndTypeId)
return VO
endfunction

function dO takes itemtype DO,integer fO returns nothing
local group g
set bj_stockPickedItemType=DO
set bj_stockPickedItemLevel=fO
set g=CreateGroup()
call GroupEnumUnitsOfType(g,"marketplace",XO)
call ForGroup(g,function UpdateEachStockBuildingEnum)
call DestroyGroup(g)
set g=null
endfunction
function FO takes nothing returns nothing
local integer pickedItemId
local itemtype gO
local integer GO=0
local integer hO=0
local integer fO
set fO=1
loop
if(bj_stockAllowedPermanent[fO])then
set hO=hO+1
if(GetRandomInt(1,hO)==1)then
set gO=ITEM_TYPE_PERMANENT
set GO=fO
endif
endif
if(bj_stockAllowedCharged[fO])then
set hO=hO+1
if(GetRandomInt(1,hO)==1)then
set gO=ITEM_TYPE_CHARGED
set GO=fO
endif
endif
if(bj_stockAllowedArtifact[fO])then
set hO=hO+1
if(GetRandomInt(1,hO)==1)then
set gO=ITEM_TYPE_ARTIFACT
set GO=fO
endif
endif
set fO=fO+1
exitwhen fO>$A
endloop
if(hO==0)then
set gO=null
return
endif
call dO(gO,GO)
set gO=null
endfunction
function HO takes nothing returns nothing
call FO()
call TimerStart(bj_stockUpdateTimer,bj_STOCK_RESTOCK_INTERVAL,true,function FO)
endfunction
function JO takes nothing returns boolean
return true
endfunction

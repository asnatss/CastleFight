function iB takes integer aB returns boolean
local integer i=Oo[Ro]
local integer j=Xo
local unit u
loop
exitwhen i>=j
if(QO(aB,Eo[i]))then
set j=j-1
set u=Eo[j]
set Eo[j]=Eo[i]
set Eo[i]=u
else
set i=i+1
endif
endloop
if(i<Xo)then
set Ro=Ro+1
set Oo[Ro]=i
endif
set u=null
call DisplayTextToPlayer(GetLocalPlayer(),.0,.0,I2S(i)+":"+I2S(j)+":"+I2S(Xo))
return j==Xo
endfunction

local integer ai
local integer bi
local real d1
local real d2
local real t
local integer i
loop
set ai=7*jh+1
set bi=7*ModuloInteger(jh+1,2)+1
set d1=un[bi+6]-Yn[ai+6]
set d2=d1
set i=1
set VV[jh*2]=6
set VV[jh*2+1]=6
loop
set t=un[bi]-Yn[ai]
if(t>d1 and un[bi]>Yn[ai])then
set d1=t
set VV[jh*2]=i
elseif(t<d2)then
set d2=t
set VV[jh*2+1]=i
endif
set ai=ai+1
set bi=bi+1
set i=i+1
exitwhen i>=nV
endloop
set jh=jh+1
exitwhen jh>=2
endloop
endfunction

loop
set T[Z]=CreateUnit(p,'h068',x,y,GetRandomReal(an,LR))
set U[Z]=500.
set W[Z]=KR
set Y[Z]=lR
if(Z==0)then
call TimerStart(S,.03,true,function jR)
endif
set Z=Z+1
set i=i+1
call TriggerSleepAction(.04)
exitwhen i>=kR
endloop
endfunction
